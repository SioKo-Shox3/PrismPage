{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PrismPage",
  "version": "0.1.0",
  "identifier": "com.sioko.prismpage",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "scripts\\tauri-dev.cmd",
    "beforeBuildCommand": "scripts\\tauri-build.cmd"
  },
  "app": {
    "windows": [
      {
        "title": "PrismPage",
        "width": 1540,
        "height": 940,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "SioKo-Shox3",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
